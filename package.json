{
    "name": "dante-astro-theme",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "start": "astro dev",
        "build": "astro build && cp _redirects dist/_redirects",
        "preview": "astro preview",
        "astro": "astro",
        "reviews:list-locations": "node scripts/fetch-google-reviews.js --list-locations",
        "reviews:fetch": "node scripts/fetch-google-reviews.js",
        "reviews:places": "node scripts/fetch-reviews-places-api.js",
        "reviews:parse": "node scripts/parse-raw-reviews.js",
        "gbp:list": "node scripts/publish-to-gbp.js --list",
        "gbp:post": "node scripts/publish-to-gbp.js",
        "gbp:post-blog": "node scripts/publish-to-gbp.js --blog",
        "gbp:schedule": "node scripts/schedule-gbp-posts.js",
        "gbp:auto": "node scripts/schedule-gbp-posts.js --auto",
        "gbp:next": "node scripts/schedule-gbp-posts.js --next",
        "gbp:images": "node scripts/copy-gbp-images.js"
    },
    "dependencies": {
        "@astrojs/mdx": "^4.3.14",
        "@astrojs/rss": "^4.0.19",
        "@astrojs/sitemap": "^3.7.3",
        "@astrojs/svelte": "^7.2.5",
        "@astrojs/tailwind": "^6.0.2",
        "@astropub/worker": "^0.2.0",
        "@splinetool/runtime": "^1.0.51",
        "@zakj/no-sleep": "^0.13.5",
        "astro": "^5.18.2",
        "astro-embed": "^0.9.0",
        "decap-cms-app": "^3.3.2",
        "dompurify": "^3.4.12",
        "gsap": "^3.12.5",
        "marked": "^18.0.7",
        "sharp": "^0.34.4",
        "svelte": "^5.56.7",
        "tailwindcss": "^3.4.1",
        "three": "^0.168.0"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.10",
        "@vite-pwa/astro": "^1.2.0",
        "prettier": "^3.2.5",
        "prettier-plugin-tailwindcss": "^0.5.11",
        "typescript": "^5.6.2"
    }
}
