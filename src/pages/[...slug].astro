---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArrowLeft from '../icons/ArrowLeft.astro';
import { Image } from 'astro:assets';
import AuthorCard from '../components/AuthorCard.astro';

export async function getStaticPaths() {
    const pages = await getCollection('pages');
    return pages.map((page) => {
        return {
            params: { slug: page.slug },
            props: { page }
        };
    });
}

type Props = { page: CollectionEntry<'pages'> };

const { page } = Astro.props;
const { title, seoTitle, image, description, backlink, canonical, schema, reviewDate } = page.data;
const { Content } = await page.render();

const monthMap: Record<string, string> = {
    'Januar': '01', 'Februar': '02', 'März': '03', 'April': '04',
    'Mai': '05', 'Juni': '06', 'Juli': '07', 'August': '08',
    'September': '09', 'Oktober': '10', 'November': '11', 'Dezember': '12',
};

function reviewDateToISO(rd: string): string {
    const parts = rd.split(' ');
    if (parts.length === 2) {
        const m = monthMap[parts[0]];
        if (m) return `${parts[1]}-${m}-01`;
    }
    return '';
}

const isoReviewDate = reviewDate ? reviewDateToISO(reviewDate) : '';

const articleSchema = reviewDate ? {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    author: {
        '@type': 'Person',
        '@id': 'https://bern-hypnose.ch/janine-aerni/#person',
        name: 'Janine Aerni',
        url: 'https://bern-hypnose.ch/janine-aerni/',
        jobTitle: 'Diplomierte Hypnosetherapeutin VSH',
        image: 'https://bern-hypnose.ch/janine-aerni-hypnose-bern-600w.jpg',
    },
    publisher: {
        '@type': 'Organization',
        '@id': 'https://bern-hypnose.ch/#organization',
        name: 'Hypnose Bern – Janine Aerni',
    },
    ...(isoReviewDate ? { dateModified: isoReviewDate } : {}),
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': `https://bern-hypnose.ch/${page.slug}/`,
    },
    inLanguage: 'de-CH',
} : null;
---

<BaseLayout title={title} seoTitle={seoTitle} description={description} canonical={canonical} schema={schema}>
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
    <article class="mb-16">
        <header class="mb-8 relative">
            {
                backlink && (
                    <a class="flex items-center absolute text-red-500 hover:text-red-700 -mt-8 text-sm font-bold" href={backlink.url}>
                        <ArrowLeft class="w-4 h-4 fill-current" />
                        <span>{backlink.title}</span>
                    </a>
                )
            }
            <h1 class="text-balance mb-8">{title}</h1>
            {
                image && (
                    <Image
                        width={1024}
                        src={image.src}
                        class="w-full rounded-xl shadow-lg"
                        alt={image.alt ?? ''}
                        widths={[360, 520, 1024]}
                        sizes="(max-width: 768px) calc(100vw - 40px), 1024px"
                    />
                )
            }
        </header>
        {reviewDate && (
            <div class="mb-8">
                <AuthorCard compact reviewDate={reviewDate} />
            </div>
        )}
        <div class="max-w-none prose prose-dante sm:prose-lg">
            <Content />
        </div>
    </article>
</BaseLayout>
