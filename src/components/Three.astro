<script>
    function isMobileDevice() {
        return /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);
    }

    if (isMobileDevice()) {
        const fallbackBg = document.getElementById('fallbackBg');
        fallbackBg?.classList.remove('hidden');
    } else {
        const worker = new Worker('/three/worker.js', { type: 'module' });
        const container = document.getElementById('threeContainer');
        const canvas = document.createElement('canvas');
        canvas.id = 'three-canvas';
        container?.appendChild(canvas);
        const offscreenCanvas = canvas.transferControlToOffscreen();

        const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

        worker.postMessage(
            {
                action: 'init',
                width: window.innerWidth,
                height: window.innerHeight,
                reducedMotion: motionQuery.matches,
                canvas: offscreenCanvas
            },
            [offscreenCanvas] // Transfer the canvas
        );

        motionQuery.addEventListener('change', (e) => {
            worker.postMessage({ action: 'motionPref', reduced: e.matches });
        });

        window.addEventListener('resize', () => {
            worker.postMessage({
                action: 'resize',
                width: window.innerWidth,
                height: window.innerHeight
            });
        });

        // Pointer proximity for gem hover reactions — rAF-throttled NDC coords
        let pointerPending = false;
        let pointerX = 0;
        let pointerY = 0;
        window.addEventListener(
            'pointermove',
            (e) => {
                pointerX = (e.clientX / window.innerWidth) * 2 - 1;
                pointerY = -(e.clientY / window.innerHeight) * 2 + 1;
                if (pointerPending) return;
                pointerPending = true;
                requestAnimationFrame(() => {
                    pointerPending = false;
                    worker.postMessage({ action: 'pointer', x: pointerX, y: pointerY });
                });
            },
            { passive: true }
        );
        const clearPointer = () => worker.postMessage({ action: 'pointer', x: null });
        window.addEventListener('blur', clearPointer);
        document.addEventListener('pointerleave', clearPointer);

        document.querySelectorAll('#menu-items [data-diamond-position]').forEach((item) => {
            item?.addEventListener('click', () => {
                worker.postMessage({
                    action: 'animate',
                    diamondPosition: item.getAttribute('data-diamond-position')
                });
            });
        });

        // Revive the legacy `document.app.emitEvent` CTA hooks (Hero + content
        // pages): clicking those buttons now triggers a gem flourish.
        (document as any).app = {
            emitEvent: () => worker.postMessage({ action: 'flourish' })
        };

        // to do: get postMessage when worker is ready
        setTimeout(() => {
            document.getElementById('threeContainer')?.classList.remove('opacity-0');
        }, 500);
    }
</script>

<div
    transition:persist
    aria-hidden="true"
    id="threeContainer"
    class="max-w-[100vw] fixed top-0 right-0 bottom-0 left-0 z-0 opacity-0 transition-opacity duration-[5000ms]"
>
</div>
<div transition:persist aria-hidden="true" id="fallbackBg" class="has-no-animation max-w-[100vw] fixed top-0 right-0 bottom-0 left-0 z-0 hidden"></div>
